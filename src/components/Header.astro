---
const base = import.meta.env.BASE_URL;
const links = [
  { href: `${base}`, label: 'Home', key: 'nav.home' },
  { href: `${base}resenhas/`, label: 'Resenhas', key: 'nav.reviews' },
  { href: `${base}entrevistas/`, label: 'Entrevistas', key: 'nav.interviews' },
  { href: `${base}colunas/`, label: 'Colunas', key: 'nav.columns' },
  { href: `${base}documentarios/`, label: 'Documentários', key: 'nav.documentaries' },
  { href: `${base}agenda/`, label: 'Agenda', key: 'nav.agenda' },
  { href: `${base}quem-somos/`, label: 'Quem Somos', key: 'nav.about' },
];
---
<header class="site-header">
  <a href={base}><img class="logo" src={`${base}logo.png`} alt="Paranoia Urbana" /></a>
  <h1 class="site-title"><a href={base}>PARANOIA URBANA</a></h1>
  <nav class="site-nav">
    {links.map((link) => <a href={link.href} data-i18n={link.key}>{link.label}</a>)}
    <span class="lang-switch">
      <button type="button" data-lang-btn="pt">PT-BR</button>
      <button type="button" data-lang-btn="en">EN</button>
    </span>
  </nav>
</header>
