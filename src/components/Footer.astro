<script>
  function updateBsbClock() {
    const el = document.getElementById('bsb-clock');
    if (!el) return;
    el.textContent = new Date().toLocaleTimeString('pt-BR', {
      timeZone: 'America/Sao_Paulo',
      hour12: false,
    });
  }
  updateBsbClock();
  setInterval(updateBsbClock, 1000);
</script>
