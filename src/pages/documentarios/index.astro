---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const items = (await getCollection('documentaries')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<BaseLayout title="Documentários">
  <h2 data-i18n="documentaries.heading">Documentários</h2>
  <ul class="article-list">
    {items.map((item) => (
      <li>
        <p class="kicker">Documentário</p>
        <h3><a href={`${base}documentarios/${item.slug}/`}>
          <span data-lang-content="pt">{item.data.title}</span>
          <span data-lang-content="en">{item.data.titleEn ?? item.data.title}</span>
        </a></h3>
        <p>
          <span data-lang-content="pt">{item.data.summary}</span>
          <span data-lang-content="en">{item.data.summaryEn ?? item.data.summary}</span>
        </p>
      </li>
    ))}
  </ul>
</BaseLayout>
